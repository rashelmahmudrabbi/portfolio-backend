# Django secret key - generate a long random string for production.
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change_this_to_a_long_random_string

# Set to False in production
DEBUG=True

# Comma-separated list of hostnames this API is served from.
# Use * for local dev; set to your real domain(s) in production.
ALLOWED_HOSTS=*

# Comma-separated list of frontend origins allowed to call this API
# e.g. https://your-frontend.vercel.app,http://localhost:5500
CORS_ORIGINS=

# Used only by `python manage.py seed_data` to create the first admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
