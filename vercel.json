{
    "version": 2,
    "builds": [
        {
            "src": "portfolio/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/portfolio/wsgi.py"
        }
    ],
    "env": {
        "DJANGO_SETTINGS_MODULE": "portfolio.settings",
        "VERCEL": "1",
        "DEBUG": "False"
    }
}